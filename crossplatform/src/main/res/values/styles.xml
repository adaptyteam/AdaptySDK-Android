<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="AdaptyVisualPaywallTheme" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="27">shortEdges</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>

    <style name="AdaptyUiScreenTransition">
        <item name="android:windowEnterAnimation">@anim/adapty_ui_slide_up</item>
        <item name="android:windowExitAnimation">@anim/adapty_ui_slide_down</item>
    </style>

    <style name="AdaptyAlertDialogTheme" parent="android:Theme.Material.Light.Dialog.Alert" />
</resources>
